{
  "name": "claude-usage-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time Claude Code analytics dashboard with a macOS menu bar companion.",
  "author": "Easton Place",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:next": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:next && npm run build:electron && electron-builder --mac",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:smoke:missing": "CLAUDE_USAGE_DISABLE_ENV_FALLBACK=1 node scripts/qa-smoke.mjs --scenario missing-optional",
    "qa:smoke:app-config": "CLAUDE_USAGE_DISABLE_ENV_FALLBACK=1 node scripts/qa-smoke.mjs --scenario app-config-only",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "@electron/remote": "^2.1.2",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.5.0",
    "framer-motion": "^11.0.0",
    "recharts": "^2.13.0",
    "lucide-react": "^0.468.0",
    "@supabase/supabase-js": "^2.47.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "react-markdown": "^9.0.1",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1",
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18"
  }
}
