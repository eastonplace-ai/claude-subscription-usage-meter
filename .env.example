# Claude Usage Dashboard — Environment Variables
# Copy this to .env.local and fill in your values

# ── Supabase (Optional) ──────────────────────────
# If set, usage data is cached in Supabase for faster retrieval
# Without these, the app falls back to direct Anthropic API via OAuth
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Token Log (Optional) ─────────────────────────
# Path to your agent token log file
# Default: ~/.claude/agents/token-log.jsonl
TOKEN_LOG_PATH=

# ── Second Brain (Optional) ──────────────────────
# Only needed if you use the Second Brain page with Obsidian + Khoj
OBSIDIAN_VAULT_PATH=
WORKSPACE_DIR=
KHOJ_URL=http://localhost:42110
KHOJ_API_KEY=
